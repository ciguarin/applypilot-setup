# ── LLM Provider (pick one) ─────────────────────────────────────────────────
# Google Gemini (recommended — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
# OPENAI_API_KEY=your_openai_key_here

# OpenRouter / any OpenAI-compatible endpoint
# LLM_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your_openrouter_key_here

# Override model for any provider
# LLM_MODEL=gemini-2.0-flash

# ── CAPTCHA Solving (optional but strongly recommended) ───────────────────────
# Sign up at https://capsolver.com — ~$2 buys hundreds of solves
CAPSOLVER_API_KEY=your_capsolver_key_here

# ── Login password for job sites (applypilot creates accounts on your behalf) ─
# Use a unique password — this goes into ATS sign-up forms, not your email
AP_PASSWORD=choose_a_strong_unique_password

# ── Email access for OTP / verification codes ────────────────────────────────
# Works with any IMAP provider:
#   iCloud:  imap.mail.me.com  / smtp.mail.me.com
#   Gmail:   imap.gmail.com    / smtp.gmail.com
#   Outlook: outlook.office365.com / smtp.office365.com
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_IMAP_HOST=imap.mail.me.com
EMAIL_SMTP_HOST=smtp.mail.me.com
